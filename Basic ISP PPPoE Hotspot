/interface bridge
add name=LAN
/ip hotspot profile
set [ find default=yes ] html-directory=hotspot
add hotspot-address=10.30.0.1 html-directory=hotspot name=hsprof1 radius-interim-update=5m use-radius=yes
/ip pool
add name=PPPoE ranges=10.20.0.2-10.20.19.99
add name=DHCP ranges=10.30.0.2-10.30.15.254

/ip hotspot
add address-pool=DHCP disabled=no interface=LAN name=HotSpot profile=hsprof1

/ip hotspot user profile
add name=1M rate-limit=1M/1M
add name=2M rate-limit=2M/2M
add name=3M rate-limit=3M/3M
add name=4M rate-limit=4M/4M
add name=5M rate-limit=5M/5M
add name=6M rate-limit=6M/6M
add name=8M rate-limit=8M/8M
add name=10M rate-limit=10M/10M
add name=15M rate-limit=15M/15M
add name=20M rate-limit=20M/20M
add name=30M rate-limit=30M/30M

/ppp profile
add local-address=10.20.0.1 name=1M only-one=yes rate-limit=1M/1M remote-address=PPPoE
add local-address=10.20.0.1 name=2M only-one=yes rate-limit=2M/2M remote-address=PPPoE
add local-address=10.20.0.1 name=3M only-one=yes rate-limit=3M/3M remote-address=PPPoE
add local-address=10.20.0.1 name=4M only-one=yes rate-limit=4M/4M remote-address=PPPoE
add local-address=10.20.0.1 name=6M only-one=yes rate-limit=6M/6M remote-address=PPPoE
add local-address=10.20.0.1 name=8M only-one=yes rate-limit=8M/8M remote-address=PPPoE
add local-address=10.20.0.1 name=10M only-one=yes rate-limit=10M/10M remote-address=PPPoE
add local-address=10.20.0.1 name=15M only-one=yes rate-limit=15M/15M remote-address=PPPoE
add local-address=10.20.0.1 name=20M only-one=yes rate-limit=20M/20M remote-address=PPPoE

/interface pppoe-server server
add authentication=pap,chap default-profile=1M disabled=no interface=LAN service-name=PPPoE
/ip address
add address=10.30.0.1/20 interface=LAN network=10.30.0.0
/ip dhcp-server
add address-pool=DHCP interface=LAN lease-time=8h name=LAN_DHCP
/ip dhcp-server network
add address=10.30.0.0/20 dns-server=10.30.0.1 gateway=10.30.0.1
/ip dns
set allow-remote-requests=yes cache-size=1000KiB servers=8.8.8.8,8.8.4.4,1.1.1.1
/ip firewall address-list
add address=10.20.0.0-10.20.19.255 list=Accepted
add address=10.30.0.0/20 list=Accepted
/ip firewall filter
add action=passthrough chain=unused-hs-chain comment="place hotspot rules here" disabled=yes
/ip firewall mangle
add action=accept chain=prerouting comment="Accept Local Address" dst-address-list=Accepted
/ip firewall nat
add action=masquerade chain=srcnat comment="NAT PPPoE" src-address=10.20.0.2-10.20.19.255
add action=masquerade chain=srcnat comment="NAT DHCP" src-address=10.30.0.0/20
/ppp aaa
set interim-update=5m use-radius=yes

